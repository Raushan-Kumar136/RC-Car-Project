#include "esp_camera.h"
#include <WiFi.h>

// 🔥 Prevent brownout reset
#include "soc/soc.h"
#include "soc/rtc_cntl_reg.h"

// ===================
// Camera Model
// ===================
#define CAMERA_MODEL_AI_THINKER
#include "camera_pins.h"

// ===========================
// WiFi Credentials
// ===========================
const char* ssid = "Jay Kumar";
const char* password = "Jay@2024";

void startCameraServer();
void setupLedFlash(int pin);

void setup() {
  Serial.begin(115200);
  Serial.setDebugOutput(false);

  // 🔥 Disable brownout detector
  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0);

  // ================= CAMERA CONFIG =================
  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer = LEDC_TIMER_0;

  config.pin_d0 = Y2_GPIO_NUM;
  config.pin_d1 = Y3_GPIO_NUM;
  config.pin_d2 = Y4_GPIO_NUM;
  config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM;
  config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM;
  config.pin_d7 = Y9_GPIO_NUM;

  config.pin_xclk = XCLK_GPIO_NUM;
  config.pin_pclk = PCLK_GPIO_NUM;
  config.pin_vsync = VSYNC_GPIO_NUM;
  config.pin_href = HREF_GPIO_NUM;

  config.pin_sccb_sda = SIOD_GPIO_NUM;
  config.pin_sccb_scl = SIOC_GPIO_NUM;

  config.pin_pwdn  = PWDN_GPIO_NUM;
  config.pin_reset = RESET_GPIO_NUM;

  config.xclk_freq_hz = 20000000;
  config.pixel_format = PIXFORMAT_JPEG;

  // 🔥 ULTRA LOW LAG SETTINGS
  config.frame_size = FRAMESIZE_QQVGA;   // 160x120 (FASTEST)
  config.jpeg_quality = 30;              // More compression = faster
  config.fb_count = 2;                  // 🔥 MUST (double buffer)
  config.grab_mode = CAMERA_GRAB_LATEST;
  config.fb_location = CAMERA_FB_IN_PSRAM;

  // Fallback if no PSRAM
  if (!psramFound()) {
    config.fb_location = CAMERA_FB_IN_DRAM;
    config.fb_count = 1;
  }

  // Init camera
  esp_err_t err = esp_camera_init(&config);
  if (err != ESP_OK) {
    Serial.printf("Camera init failed: 0x%x", err);
    delay(2000);
    ESP.restart();
  }

  Serial.println("Camera initialized");

  // ================= SENSOR TUNING =================
  sensor_t * s = esp_camera_sensor_get();

  s->set_framesize(s, FRAMESIZE_QQVGA);
  s->set_quality(s, 30);

  // 🔥 Disable ALL heavy processing
  s->set_gain_ctrl(s, 0);
  s->set_exposure_ctrl(s, 0);
  s->set_whitebal(s, 0);
  s->set_denoise(s, 0);
  s->set_aec2(s, 0);

#if defined(LED_GPIO_NUM)
  setupLedFlash(LED_GPIO_NUM);
#endif

  // ================= WIFI =================
  WiFi.begin(ssid, password);
  WiFi.setSleep(false);
  WiFi.setTxPower(WIFI_POWER_19_5dBm);  // 🔥 max WiFi power

  Serial.print("Connecting WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(300);
    Serial.print(".");
  }

  Serial.println("\nWiFi connected");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  startCameraServer();

  Serial.println("🔥 ULTRA FAST STREAM READY");
  Serial.println("Open browser → http://<IP>");
}

// ================= LOOP (AUTO RECOVERY) =================
void loop() {

  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi lost. Reconnecting...");

    WiFi.disconnect();
    WiFi.begin(ssid, password);

    int retry = 0;
    while (WiFi.status() != WL_CONNECTED && retry < 10) {
      delay(500);
      Serial.print(".");
      retry++;
    }

    if (WiFi.status() != WL_CONNECTED) {
      Serial.println("\nRestarting ESP...");
      ESP.restart();
    }

    Serial.println("\nReconnected!");
  }

  delay(1000);
}
